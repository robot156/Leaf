<resources>

    <style name="Theme.Leaf" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <style name="Theme.Leaf.Splash" parent="Theme.SplashScreen">
